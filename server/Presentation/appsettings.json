{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    "AllowedHosts": "*",
    "MqttOptions": {
        "Host": "localhost",
        "Port": 1883,
        "ClientId": "server",
        "Username": "",
