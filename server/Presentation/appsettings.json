    },
    "CommandLifecycle": {
        "PendingTimeoutSeconds": 30,
        "SweepIntervalSeconds": 10,
        "BatchSize": 200
    },
    "CapabilityRegistry": {
        "FilePath": "capability-registry/index.json"
    },
    "DeviceCategoryRegistry": {
        "FilePath": "device-category-registry/index.json"
